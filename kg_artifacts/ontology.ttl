@prefix mcu: <http://example.org/mcu/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prop: <http://example.org/mcu/property/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

mcu:PhaseThreeFilm a owl:Class ;
    rdfs:label "PhaseThreeFilm"@en ;
    rdfs:comment "A film inferred to be part of Phase 3."@en .

mcu:ReleaseYear a owl:Class ;
    rdfs:label "ReleaseYear"@en ;
    rdfs:comment "A release year represented as an entity."@en .

mcu:SagaFilm a owl:Class ;
    rdfs:label "SagaFilm"@en ;
    rdfs:comment "A film inferred to belong to a saga-oriented category."@en .

mcu:lead a mcu:RoleType ;
    rdfs:label "lead"@en .

prop:appearsInFilm a owl:ObjectProperty ;
    rdfs:label "appearsInFilm"@en ;
    rdfs:comment "Links a character or actor appearance to a film."@en ;
    rdfs:domain mcu:Character ;
    rdfs:range mcu:Film .

prop:directedBy a owl:ObjectProperty ;
    rdfs:label "directedBy"@en ;
    rdfs:comment "Links a film to its director."@en ;
    rdfs:domain mcu:Film ;
    rdfs:range mcu:Director .

prop:followsFilm a owl:ObjectProperty ;
    rdfs:label "followsFilm"@en ;
    rdfs:comment "Links a film to a previous release in the selected corpus."@en ;
    rdfs:domain mcu:Film ;
    rdfs:range mcu:Film .

prop:hasCastMember a owl:ObjectProperty ;
    rdfs:label "hasCastMember"@en ;
    rdfs:comment "Links a film to a cast member."@en ;
    rdfs:domain mcu:Film ;
    rdfs:range mcu:Actor .

prop:hasCountry a owl:ObjectProperty ;
    rdfs:label "hasCountry"@en ;
    rdfs:comment "Links a film to a country."@en ;
    rdfs:domain mcu:Film ;
    rdfs:range mcu:Country .

prop:hasGenre a owl:ObjectProperty ;
    rdfs:label "hasGenre"@en ;
    rdfs:comment "Links a film to a genre."@en ;
    rdfs:domain mcu:Film ;
    rdfs:range mcu:Genre .

prop:hasRoleType a owl:ObjectProperty ;
    rdfs:label "hasRoleType"@en ;
    rdfs:comment "Links an actor appearance to a role type."@en ;
    rdfs:domain mcu:Actor ;
    rdfs:range mcu:RoleType .

prop:hasTag a owl:ObjectProperty ;
    rdfs:label "hasTag"@en ;
    rdfs:comment "Links a film to a thematic tag."@en ;
    rdfs:domain mcu:Film ;
    rdfs:range mcu:Tag .

prop:partOfFranchise a owl:ObjectProperty ;
    rdfs:label "partOfFranchise"@en ;
    rdfs:comment "Links a film to a franchise."@en ;
    rdfs:domain mcu:Film ;
    rdfs:range mcu:Franchise .

prop:partOfPhase a owl:ObjectProperty ;
    rdfs:label "partOfPhase"@en ;
    rdfs:comment "Links a film to an MCU phase."@en ;
    rdfs:domain mcu:Film ;
    rdfs:range mcu:Phase .

prop:portraysCharacter a owl:ObjectProperty ;
    rdfs:label "portraysCharacter"@en ;
    rdfs:comment "Links an actor to a portrayed character."@en ;
    rdfs:domain mcu:Actor ;
    rdfs:range mcu:Character .

prop:producedBy a owl:ObjectProperty ;
    rdfs:label "producedBy"@en ;
    rdfs:comment "Links a film to its studio."@en ;
    rdfs:domain mcu:Film ;
    rdfs:range mcu:Studio .

prop:releaseDate a owl:DatatypeProperty ;
    rdfs:label "releaseDate"@en ;
    rdfs:comment "Release date of the film."@en ;
    rdfs:domain mcu:Film ;
    rdfs:range xsd:date .

prop:releaseYear a owl:DatatypeProperty ;
    rdfs:label "releaseYear"@en ;
    rdfs:comment "Release year of the film."@en ;
    rdfs:domain mcu:Film ;
    rdfs:range xsd:gYear .

prop:samePhaseAs a owl:ObjectProperty ;
    rdfs:label "samePhaseAs"@en ;
    rdfs:comment "Derived relation for phase membership."@en ;
    rdfs:domain mcu:Film ;
    rdfs:range mcu:Film .

prop:sharesCastMemberWith a owl:ObjectProperty ;
    rdfs:label "sharesCastMemberWith"@en ;
    rdfs:comment "Derived relation for common cast."@en ;
    rdfs:domain mcu:Film ;
    rdfs:range mcu:Film .

prop:sharesDirectorWith a owl:ObjectProperty ;
    rdfs:label "sharesDirectorWith"@en ;
    rdfs:comment "Derived relation for common directors."@en ;
    rdfs:domain mcu:Film ;
    rdfs:range mcu:Film .

prop:sharesGenreWith a owl:ObjectProperty ;
    rdfs:label "sharesGenreWith"@en ;
    rdfs:comment "Derived relation for common genre."@en ;
    rdfs:domain mcu:Film ;
    rdfs:range mcu:Film .

mcu:supporting a mcu:RoleType ;
    rdfs:label "supporting"@en .

mcu:villain a mcu:RoleType ;
    rdfs:label "villain"@en .

mcu:Country a owl:Class ;
    rdfs:label "Country"@en ;
    rdfs:comment "A production country."@en .

mcu:Director a owl:Class ;
    rdfs:label "Director"@en ;
    rdfs:comment "A film director working on an MCU film."@en .

mcu:Franchise a owl:Class ;
    rdfs:label "Franchise"@en ;
    rdfs:comment "A film franchise."@en .

mcu:Genre a owl:Class ;
    rdfs:label "Genre"@en ;
    rdfs:comment "A film genre."@en .

mcu:Phase a owl:Class ;
    rdfs:label "Phase"@en ;
    rdfs:comment "A release phase of the MCU."@en .

mcu:Studio a owl:Class ;
    rdfs:label "Studio"@en ;
    rdfs:comment "A production studio."@en .

mcu:Tag a owl:Class ;
    rdfs:label "Tag"@en ;
    rdfs:comment "A thematic tag used for analysis and expansion."@en .

mcu:Character a owl:Class ;
    rdfs:label "Character"@en ;
    rdfs:comment "A fictional character appearing in an MCU film."@en .

mcu:Actor a owl:Class ;
    rdfs:label "Actor"@en ;
    rdfs:comment "A cast member in an MCU film."@en .

mcu:RoleType a owl:Class ;
    rdfs:label "RoleType"@en ;
    rdfs:comment "A cast role category such as lead or villain."@en .

mcu:Film a owl:Class ;
    rdfs:label "Film"@en ;
    rdfs:comment "An MCU feature film."@en .

