<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://example.org/mcu-swrl/"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#"
         xmlns="http://example.org/mcu-swrl/">

<owl:Ontology rdf:about="http://example.org/mcu-swrl"/>

<owl:ObjectProperty rdf:about="partOfPhase">
  <rdfs:domain rdf:resource="Film"/>
  <rdfs:range rdf:resource="Phase"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="hasGenre">
  <rdfs:domain rdf:resource="Film"/>
  <rdfs:range rdf:resource="Genre"/>
</owl:ObjectProperty>

<owl:Class rdf:about="Film">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="Genre">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="Phase">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="PhaseThreeFilm">
  <rdfs:subClassOf rdf:resource="Film"/>
</owl:Class>

<owl:Class rdf:about="SuperheroGenre">
  <rdfs:subClassOf rdf:resource="Genre"/>
</owl:Class>

<owl:Class rdf:about="PhaseThreeSagaFilm">
  <rdfs:subClassOf rdf:resource="Film"/>
</owl:Class>

<owl:NamedIndividual rdf:about="Phase_3">
  <rdf:type rdf:resource="Phase"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="Superhero_film">
  <rdf:type rdf:resource="SuperheroGenre"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="Action_film">
  <rdf:type rdf:resource="Genre"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="Avengers_Infinity_War">
  <rdf:type rdf:resource="Film"/>
  <partOfPhase rdf:resource="Phase_3"/>
  <hasGenre rdf:resource="Superhero_film"/>
  <hasGenre rdf:resource="Action_film"/>
  <rdf:type rdf:resource="PhaseThreeSagaFilm"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="Avengers_Endgame">
  <rdf:type rdf:resource="Film"/>
  <partOfPhase rdf:resource="Phase_3"/>
  <hasGenre rdf:resource="Superhero_film"/>
  <hasGenre rdf:resource="Action_film"/>
  <rdf:type rdf:resource="PhaseThreeSagaFilm"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="Iron_Man">
  <rdf:type rdf:resource="Film"/>
  <partOfPhase rdf:resource="Phase_1"/>
  <hasGenre rdf:resource="Superhero_film"/>
  <hasGenre rdf:resource="Action_film"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="Phase_1">
  <rdf:type rdf:resource="Phase"/>
</owl:NamedIndividual>

<swrl:Variable rdf:about="urn:swrl#f"/>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="Film"/>
          <swrl:argument1 rdf:resource="urn:swrl#f"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:IndividualPropertyAtom>
              <swrl:propertyPredicate rdf:resource="partOfPhase"/>
              <swrl:argument1 rdf:resource="urn:swrl#f"/>
              <swrl:argument2 rdf:resource="Phase_3"/>
            </swrl:IndividualPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:IndividualPropertyAtom>
                  <swrl:propertyPredicate rdf:resource="hasGenre"/>
                  <swrl:argument1 rdf:resource="urn:swrl#f"/>
                  <swrl:argument2 rdf:resource="Superhero_film"/>
                </swrl:IndividualPropertyAtom>
              </rdf:first>
              <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="PhaseThreeSagaFilm"/>
          <swrl:argument1 rdf:resource="urn:swrl#f"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>


</rdf:RDF>
